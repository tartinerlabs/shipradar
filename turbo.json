{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "envMode": "loose",
  "remoteCache": {
    "signature": true
  },
  "globalDependencies": ["tsconfig.json", "biome.json", ".env"],
  "globalEnv": ["NODE_ENV"],
  "globalPassThroughEnv": [
    "BETTER_AUTH_*",
    "CRON_SECRET",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "DISCORD_*",
    "GITHUB_*",
    "GOOGLE_*",
    "HEROUI_AUTH_TOKEN",
    "POSTHOG_API_KEY",
    "TELEGRAM_BOT_TOKEN",
    "UPSTASH_*"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "$TURBO_DEFAULT$",
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".output"
      ]
    },
    "preview": {},
    "start": {
      "dependsOn": ["build"],
      "persistent": true,
      "with": ["@shipradar/api#dev"]
    },
    "lint": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "format": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "typecheck": {},
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "auth:generate": {
      "cache": false,
      "interactive": true
    },
    "db:drop": {
      "cache": false,
      "interactive": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "interactive": true
    }
  }
}
