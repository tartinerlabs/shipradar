{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": ["DATABASE_URL", "HEROUI_AUTH_TOKEN", "UPSTASH_*"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "start": {
      "dependsOn": ["build"],
      "persistent": true,
      "with": ["@shipradar/api#dev"]
    },
    "lint": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "format": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "auth:generate": {
      "cache": false,
      "interactive": true
    },
    "db:drop": {
      "cache": false,
      "interactive": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "interactive": true
    }
  }
}
