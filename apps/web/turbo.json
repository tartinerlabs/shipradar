{
  "$schema": "../../node_modules/turbo/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_DISCORD_CLIENT_ID",
        "NEXT_PUBLIC_POSTHOG_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", "!README.md", ".env", ".env.*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "start": {
      "dependsOn": ["build"],
      "persistent": true
    }
  }
}
